{
  "expo": {
    "name": "PPL Tracker",
    "slug": "my-ppl-tracker",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0C0C0B"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "backgroundColor": "#0C0C0B",
      "supportsTablet": false,
      "bundleIdentifier": "com.solehack.ppltracker",
      "infoPlist": {
        "NSCameraUsageDescription": "Take progress photos to track your physique over time.",
        "NSPhotoLibraryUsageDescription": "Choose photos from your library for progress tracking.",
        "NSPhotoLibraryAddUsageDescription": "Save progress photos to your library."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0C0C0B"
      },
      "package": "com.solehack.ppltracker",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.VIBRATE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-video"
    ],
    "scheme": "ppltracker",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "bb56aa8b-9d59-40da-a6f3-61139d97f6e8"
      }
    },
    "owner": "roamroulette"
  }
}
