{
  "expo": {
    "name": "PPL Tracker",
    "slug": "ppl-tracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0C0C0B"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "backgroundColor": "#0C0C0B",
      "supportsTablet": false,
      "bundleIdentifier": "com.solehack.ppltracker",
      "infoPlist": {
        "NSCameraUsageDescription": "Take progress photos to track your physique over time.",
        "NSPhotoLibraryUsageDescription": "Choose photos from your library for progress tracking.",
        "NSPhotoLibraryAddUsageDescription": "Save progress photos to your library."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0C0C0B"
      },
      "package": "com.solehack.ppltracker",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.VIBRATE"
      ]
    },
    "web": { "favicon": "./assets/favicon.png" },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-video",
      ["expo-camera", { "cameraPermission": "Allow PPL Tracker to access your camera for progress photos." }]
    ],
    "scheme": "ppltracker",
    "experiments": { "typedRoutes": true }
  }
}